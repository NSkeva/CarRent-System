<div class="global-search-backdrop" data-global-search-backdrop hidden></div>
<div class="global-search-modal" data-global-search-modal hidden role="dialog" aria-label="Globalna pretraga">
    <div class="global-search-inner">
        <input type="search"
               class="global-search-input"
               data-global-search-input
               placeholder="Pretraži stranice, vozila, kupce, rezervacije… (Ctrl+K)"
               autocomplete="off" />
        <div class="global-search-results" data-global-search-results></div>
        <div class="global-search-hint">↑↓ navigacija · Enter otvori · Esc zatvori</div>
    </div>
</div>
