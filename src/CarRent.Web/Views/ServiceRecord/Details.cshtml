@model ServiceRecord

<section class="panel detail-card">
    <h1>Servis #@Model.Id</h1>
    <p><strong>Vozilo ID:</strong> @Model.VehicleId</p>
    <p><strong>Datum:</strong> @Model.ServiceDate:yyyy-MM-dd</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Opis:</strong> @Model.Description</p>
    <p><strong>Kilometraza:</strong> @Model.MileageAtService km</p>
    <p><strong>Trosak:</strong> @Model.Cost EUR</p>
    <p><strong>Preporuceni iduci servis:</strong> @(Model.NextRecommendedServiceDate?.ToString("yyyy-MM-dd") ?? "-")</p>
    <div class="panel-actions">
        <a asp-action="Index" class="btn btn-secondary btn-sm">← Natrag na listu</a>
    </div>
</section>
