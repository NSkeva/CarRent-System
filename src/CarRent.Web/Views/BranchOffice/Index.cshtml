@model IReadOnlyList<BranchOffice>
@{
    ViewData["Title"] = "Poslovnice";
    ViewData["Breadcrumbs"] = BreadcrumbHelper.Build("Home", "Poslovnice");
}
<partial name="_CrudIndexHeaderPartial" model='("Poslovnice", "Nova poslovnica", Url.Action("SearchRows"), "branch-rows")' />
<div class="table-wrap rise-in">
    <table class="data-table">
        <thead><tr><th>Naziv</th><th>Tip</th><th>Adresa</th><th>Telefon</th><th></th></tr></thead>
        <tbody id="branch-rows"><partial name="_IndexRows" model="Model" /></tbody>
    </table>
</div>
