@model DailyPlanVm
@{
    ViewData["Title"] = "Dnevni plan";
    ViewData["Breadcrumbs"] = BreadcrumbHelper.Build("Home", "Dnevni plan");
    var dayInputValue = $"{Model.Day:yyyy-MM-dd}";
}

<div class="plan-header no-print">
    <h1>Dnevni plan</h1>
    <form method="get" class="date-input-group" style="display:flex;align-items:center;gap:8px">
        <label for="day">Datum</label>
        <input type="date" id="day" name="day" value="@dayInputValue" class="field-input" style="width:auto" />
        <button type="submit" class="btn btn-secondary btn-sm">Učitaj</button>
        <button type="button" class="btn btn-ghost btn-sm" onclick="window.print()">🖨 Ispis A4</button>
    </form>
</div>

<div class="plan-cols">
    <div class="glass">
        <div class="plan-col-header">
            <div class="col-icon povrat">↙</div>
            <h2>Povrati</h2>
            <span class="count">@Model.Returns.Count</span>
        </div>
        @if (!Model.Returns.Any())
        {
            <div class="empty-state"><p>Nema povrata za odabrani dan.</p></div>
        }
        @foreach (var item in Model.Returns)
        {
            <div class="ev-card return">
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                    <div>
                        <div class="ev-vehicle">@item.Vehicle.Brand @item.Vehicle.Model</div>
                        <div class="ev-reg">@item.Vehicle.RegistrationNumber</div>
                    </div>
                    <div class="ev-time">@item.Reservation.EndDate.ToString("HH:mm")</div>
                </div>
                <div style="font-size:13px;color:var(--muted);margin:6px 0">@item.Customer.FirstName @item.Customer.LastName</div>
                <div class="day-card-actions">
                    <a asp-controller="Reservation" asp-action="Details" asp-route-id="@item.Reservation.Id" class="btn btn-secondary btn-sm">Detalji</a>
                </div>
            </div>
        }
    </div>
    <div class="glass">
        <div class="plan-col-header">
            <div class="col-icon odlaz">↗</div>
            <h2>Odlasci</h2>
            <span class="count">@Model.Departures.Count</span>
        </div>
        @if (!Model.Departures.Any())
        {
            <div class="empty-state"><p>Nema odlazaka za odabrani dan.</p></div>
        }
        @foreach (var item in Model.Departures)
        {
            <div class="ev-card">
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                    <div>
                        <div class="ev-vehicle">@item.Vehicle.Brand @item.Vehicle.Model</div>
                        <div class="ev-reg">@item.Vehicle.RegistrationNumber</div>
                    </div>
                    <div class="ev-time">@item.Reservation.StartDate.ToString("HH:mm")</div>
                </div>
                <div style="font-size:13px;color:var(--muted);margin:6px 0">@item.Customer.FirstName @item.Customer.LastName</div>
                <div class="day-card-actions">
                    <a asp-controller="Reservation" asp-action="Details" asp-route-id="@item.Reservation.Id" class="btn btn-secondary btn-sm">Detalji</a>
                </div>
            </div>
        }
    </div>
</div>
