@model Employee

<section class="panel detail-card">
    <h1>@Model.FirstName @Model.LastName</h1>
    <p><strong>Pozicija:</strong> @Model.JobTitle</p>
    <p><strong>Poslovnica ID:</strong> @Model.BranchOfficeId</p>
    <p><strong>Zaposlen od:</strong> @Model.HiredAt:yyyy-MM-dd</p>
    <div class="panel-actions">
        <a asp-action="Index" class="btn btn-secondary btn-sm">← Natrag na listu</a>
    </div>
</section>
