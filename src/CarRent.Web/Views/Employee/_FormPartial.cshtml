@model EmployeeFormVm
<form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post" class="crud-form">
    <input type="hidden" asp-for="Id" />
    <div class="field"><label asp-for="FirstName"></label><input asp-for="FirstName" class="form-control" /><span asp-validation-for="FirstName" class="field-error"></span></div>
    <div class="field"><label asp-for="LastName"></label><input asp-for="LastName" class="form-control" /><span asp-validation-for="LastName" class="field-error"></span></div>
    <div class="field"><label asp-for="JobTitle"></label><input asp-for="JobTitle" class="form-control" /><span asp-validation-for="JobTitle" class="field-error"></span></div>
    <partial name="_AutocompletePartial" model='new AutocompleteFieldVm { InputId = "empBranch", HiddenName = "BranchOfficeId", Label = "Poslovnica", SearchUrl = "/api/lookup/branches", SelectedId = Model.BranchOfficeId, DisplayText = Model.BranchOfficeDisplay }' />
    <partial name="_DateTimePartial" model='new DateTimeFieldVm { FieldName = "HiredAt", Label = "Datum zaposlenja", Value = Model.HiredAt }' />
    <div class="actions"><button type="submit" class="btn-primary">Spremi</button><a asp-action="Index">Odustani</a></div>
</form>
