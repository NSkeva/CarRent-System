@model Vehicle
@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
    var branchName = Model.BranchOffice?.Name ?? "—";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var fromFleet = ViewData["NavSection"] as string == "operativa";
    var vehicleReturn = Url.Action("Details", "Vehicle", new { id = Model.Id, returnUrl });
    var attachments = Model.Attachments.OrderByDescending(a => a.CreatedAt).ToList();
    var mainImageUrl = VehicleImageHelper.GetDisplayUrl(Model);
    var reservationEvents = VehicleRegistrationHelper.BuildTabEvents(Model);
}

<div class="vehicle-hero rise-in">
    <div class="hero-visual vehicle-hero-photo">
        <img id="vehicleHeroImage" src="@mainImageUrl" alt="@Model.Brand @Model.Model" />
    </div>
    <div class="hero-info">
        <div class="hero-eyebrow">Vozilo</div>
        <h1 class="hero-title" style="font-size:26px">@Model.Brand @Model.Model</h1>
        <div class="hero-reg">@Model.RegistrationNumber</div>
        <div class="hero-stats" style="display:flex;flex-wrap:wrap;gap:6px">
            <span class="chip @(Model.IsActive ? "chip-completed" : "chip-cancelled")">@(Model.IsActive ? "Aktivno" : "Neaktivno")</span>
            <span style="font-size:12px;color:var(--muted);padding:4px 10px;border:1px solid var(--line);border-radius:20px">@Model.Type · @Model.Year</span>
            <span style="font-size:12px;color:var(--muted);padding:4px 10px;border:1px solid var(--line);border-radius:20px">🏢 @branchName</span>
        </div>
        <div class="hero-price">@Model.DailyPrice.ToString("N0") <span style="font-size:14px;font-weight:400;color:var(--muted)">EUR/dan</span></div>
        <div class="hero-actions vehicle-hero-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl" class="btn btn-primary btn-sm">Uredi vozilo</a>
            @if (fromFleet && !string.IsNullOrEmpty(returnUrl))
            {
                <a href="@returnUrl" class="btn btn-secondary btn-sm">← Vozni park</a>
            }
            else if (User.IsInRole("Admin"))
            {
                <a asp-action="Index" class="btn btn-secondary btn-sm">← Lista vozila</a>
            }
            else
            {
                <a asp-controller="Fleet" asp-action="Index" class="btn btn-secondary btn-sm">← Vozni park</a>
            }
        </div>
    </div>
</div>

<div class="tabs-bar" role="tablist">
    <button type="button" class="tab-btn active" data-tab="pregled">Pregled</button>
    <button type="button" class="tab-btn" data-tab="rezervacije">Rezervacije (@reservationEvents.Count)</button>
    <button type="button" class="tab-btn" data-tab="servisi">Servisi (@Model.ServiceRecords.Count)</button>
    <button type="button" class="tab-btn" data-tab="dokumenti">Dokumenti (@attachments.Count)</button>
</div>

<div id="pregled" class="tab-panel active">
    <div class="tab-toolbar">
        <h3 class="tab-toolbar-title">Osnovni podaci</h3>
        <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl" class="btn btn-primary btn-sm">Uredi vozilo</a>
    </div>
    <div class="detail-grid">
        <div class="glass">
            <div class="form-section-title">Osnovno</div>
            <div class="detail-row"><span>Registracija</span><span>@Model.RegistrationNumber</span></div>
            <div class="detail-row"><span>Datum registracije</span><span>@(Model.RegistrationDueDate?.ToString("dd.MM.yyyy") ?? "—")</span></div>
            <div class="detail-row"><span>Kilometraža</span><span>@Model.MileageKm km</span></div>
            <div class="detail-row"><span>Poslovnica</span><span>@branchName</span></div>
        </div>
        <div class="glass">
            <div class="form-section-title">Cijena i status</div>
            <div class="detail-row"><span>Cijena / dan</span><span>@Model.DailyPrice EUR</span></div>
            <div class="detail-row"><span>Godina</span><span>@Model.Year</span></div>
            <div class="detail-row"><span>Tip</span><span>@Model.Type</span></div>
        </div>
    </div>
</div>

<div id="rezervacije" class="tab-panel">
    <div class="tab-toolbar">
        <h3 class="tab-toolbar-title">Rezervacije vozila</h3>
        <a asp-controller="Reservation" asp-action="Create" asp-route-vehicleId="@Model.Id" asp-route-returnUrl="@vehicleReturn" class="btn btn-primary btn-sm">+ Nova rezervacija</a>
    </div>
    @if (!reservationEvents.Any())
    {
        <p class="tab-empty">Nema rezervacija za ovo vozilo.</p>
    }
    else
    {
        <div class="tab-event-filters filter-bar glass glass-sm rise-in">
            <input type="search" id="resFilterQ" class="field-input tab-event-search" placeholder="Pretraga (kupac, ID)…" autocomplete="off" />
            <select id="resFilterType" class="field-select tab-event-select" aria-label="Tip stavke">
                <option value="">Sve stavke</option>
                <option value="reservation">Rezervacije</option>
                <option value="registration">Registracije</option>
            </select>
            <select id="resFilterStatus" class="field-select tab-event-select" aria-label="Status">
                <option value="">Svi statusi</option>
                <option value="registration">Registracija</option>
                @foreach (var status in Enum.GetValues<ReservationStatus>())
                {
                    <option value="@status.ToString().ToLowerInvariant()">@UiDisplayHelper.ReservationStatusLabel(status)</option>
                }
            </select>
            <select id="resFilterSort" class="field-select tab-event-select" aria-label="Sortiranje">
                <option value="date-desc">Datum ↓ (najnovije)</option>
                <option value="date-asc">Datum ↑ (najstarije)</option>
                <option value="customer-asc">Kupac A–Z</option>
                <option value="status-asc">Status A–Z</option>
                <option value="id-desc">ID ↓</option>
            </select>
            <span id="resFilterMeta" class="tab-filter-meta"></span>
        </div>
        <p id="resFilterEmpty" class="tab-empty" hidden>Nema stavki za odabrane filtere.</p>
        <div class="table-wrap" id="vehicleResTableWrap">
            <table class="data-table" id="vehicleResTable">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="id" data-sort-default="desc">ID</th>
                        <th class="sortable" data-sort="customer" data-sort-default="asc">Kupac</th>
                        <th class="sortable sort-desc" data-sort="date" data-sort-default="desc">Period</th>
                        <th class="sortable" data-sort="status" data-sort-default="asc">Status</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ev in reservationEvents)
                {
                    if (ev.IsRegistration)
                    {
                        var regStatusKey = ev.RegistrationIsPast ? "completed" : ev.RegistrationIsToday ? "active" : "registration";
                        var regStatusLabel = ev.RegistrationIsPast ? "Završeno" : ev.RegistrationIsToday ? "Danas" : "Registracija";
                        var regChipClass = ev.RegistrationIsPast
                            ? UiDisplayHelper.ReservationChipClass(ReservationStatus.Completed)
                            : ev.RegistrationIsToday
                                ? UiDisplayHelper.ReservationChipClass(ReservationStatus.Active)
                                : UiDisplayHelper.RegistrationChipClass();
                        <tr class="row-registration @(ev.RegistrationIsPast ? "row-registration-past" : "")"
                            data-event-type="registration"
                            data-status="@regStatusKey"
                            data-date="@ev.SortDate.ToString("o")"
                            data-customer=""
                            data-id="0">
                            <td><span class="tbl-id">REG</span></td>
                            <td>—</td>
                            <td>@ev.SortDate.ToString("dd.MM.yyyy") <span style="color:var(--muted);font-size:12px">(godišnje)</span></td>
                            <td><partial name="_StatusChip" model="@(regChipClass, regStatusLabel)" /></td>
                            <td>—</td>
                        </tr>
                    }
                    else
                    {
                        var r = ev.Reservation!;
                        var customerName = r.Customer is null ? "" : $"{r.Customer.FirstName} {r.Customer.LastName}";
                        <tr data-event-type="reservation"
                            data-status="@r.Status.ToString().ToLowerInvariant()"
                            data-date="@r.StartDate.ToString("o")"
                            data-customer="@customerName.ToLowerInvariant()"
                            data-id="@r.Id">
                            <td><span class="tbl-id">#@r.Id</span></td>
                            <td>@(string.IsNullOrEmpty(customerName) ? "—" : customerName)</td>
                            <td>@r.StartDate.ToString("g") – @r.EndDate.ToString("g")</td>
                            <td><partial name="_StatusChip" model="@(UiDisplayHelper.ReservationChipClass(r.Status), UiDisplayHelper.ReservationStatusLabel(r.Status))" /></td>
                            <td class="row-actions">
                                <a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.Id" class="btn btn-ghost btn-sm">Detalji</a>
                                <a asp-controller="Reservation" asp-action="Edit" asp-route-id="@r.Id" asp-route-returnUrl="@vehicleReturn" class="btn btn-ghost btn-sm">Uredi</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div id="servisi" class="tab-panel">
    <div class="tab-toolbar">
        <h3 class="tab-toolbar-title">Servisna povijest</h3>
        <a asp-controller="ServiceRecord" asp-action="Create" asp-route-vehicleId="@Model.Id" asp-route-returnUrl="@vehicleReturn" class="btn btn-primary btn-sm">+ Novi servis</a>
    </div>
    @if (!Model.ServiceRecords.Any())
    {
        <p class="tab-empty">Nema evidentiranih servisa.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>Datum</th><th>Status</th><th>Opis</th><th>Trošak</th><th>Akcije</th></tr></thead>
                <tbody>
                @foreach (var s in Model.ServiceRecords.OrderByDescending(x => x.ServiceDate))
                {
                    <tr>
                        <td>@s.ServiceDate.ToString("g")</td>
                        <td><partial name="_StatusChip" model="@(UiDisplayHelper.ServiceChipClass(s.Status), s.Status.ToString())" /></td>
                        <td>@s.Description</td>
                        <td>@s.Cost.ToString("N2") €</td>
                        <td class="row-actions">
                            <a asp-controller="ServiceRecord" asp-action="Details" asp-route-id="@s.Id" class="btn btn-ghost btn-sm">Detalji</a>
                            <a asp-controller="ServiceRecord" asp-action="Edit" asp-route-id="@s.Id" asp-route-returnUrl="@vehicleReturn" class="btn btn-ghost btn-sm">Uredi</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div id="dokumenti" class="tab-panel">
    <div class="tab-toolbar">
        <h3 class="tab-toolbar-title">Dokumenti vozila</h3>
        <button type="button" class="btn btn-primary btn-sm" id="btnNewDocument">+ Novi dokument</button>
    </div>
    <form id="vehicleDocDz"
          asp-controller="Vehicle"
          asp-action="UploadAttachment"
          asp-route-vehicleId="@Model.Id"
          enctype="multipart/form-data"
          class="dropzone attachment-dropzone vehicle-doc-dropzone is-collapsed">
    </form>
    <div id="attachmentList">
        <partial name="_AttachmentList" model="@attachments" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/min/dropzone.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/min/dropzone.min.js"></script>
    <script>
        const vehicleId = @Model.Id;

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(btn.dataset.tab)?.classList.add('active');
            });
        });

        (function initReservationTabFilters() {
            const table = document.getElementById('vehicleResTable');
            if (!table) return;

            const tbody = table.querySelector('tbody');
            const qInput = document.getElementById('resFilterQ');
            const typeSelect = document.getElementById('resFilterType');
            const statusSelect = document.getElementById('resFilterStatus');
            const sortSelect = document.getElementById('resFilterSort');
            const meta = document.getElementById('resFilterMeta');
            const emptyEl = document.getElementById('resFilterEmpty');
            const tableWrap = document.getElementById('vehicleResTableWrap');
            const sortHeaders = table.querySelectorAll('th.sortable');

            const rows = () => Array.from(tbody.querySelectorAll('tr'));
            let sortKey = 'date';
            let sortDir = 'desc';

            function parseSort(value) {
                const [key, dir] = value.split('-');
                return { key, dir: dir === 'asc' ? 'asc' : 'desc' };
            }

            function syncSortUi() {
                sortHeaders.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
                const active = table.querySelector(`th.sortable[data-sort="${sortKey}"]`);
                active?.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
                if (sortSelect) {
                    const optionValue = `${sortKey}-${sortDir}`;
                    if ([...sortSelect.options].some(o => o.value === optionValue))
                        sortSelect.value = optionValue;
                }
            }

            function sortRows() {
                const sorted = rows().sort((a, b) => {
                    let cmp = 0;
                    if (sortKey === 'date')
                        cmp = new Date(a.dataset.date) - new Date(b.dataset.date);
                    else if (sortKey === 'customer')
                        cmp = (a.dataset.customer || '').localeCompare(b.dataset.customer || '', 'hr');
                    else if (sortKey === 'status')
                        cmp = a.dataset.status.localeCompare(b.dataset.status, 'hr');
                    else if (sortKey === 'id')
                        cmp = (parseInt(a.dataset.id, 10) || 0) - (parseInt(b.dataset.id, 10) || 0);
                    return sortDir === 'asc' ? cmp : -cmp;
                });
                sorted.forEach(row => tbody.appendChild(row));
            }

            function applyFilters() {
                const q = (qInput?.value || '').trim().toLowerCase();
                const type = typeSelect?.value || '';
                const status = statusSelect?.value || '';
                let visible = 0;
                const total = rows().length;

                rows().forEach(row => {
                    const idText = row.dataset.id || '';
                    const customer = row.dataset.customer || '';
                    const haystack = `${idText} ${customer} ${row.textContent}`.toLowerCase();
                    const matchQ = !q || haystack.includes(q);
                    const matchType = !type || row.dataset.eventType === type;
                    const matchStatus = !status || row.dataset.status === status;
                    const show = matchQ && matchType && matchStatus;
                    row.hidden = !show;
                    if (show) visible++;
                });

                if (meta)
                    meta.textContent = visible === total ? `${total} stavki` : `Prikazano ${visible} od ${total}`;
                if (emptyEl) emptyEl.hidden = visible > 0;
                if (tableWrap) tableWrap.hidden = visible === 0;
            }

            function refresh() {
                sortRows();
                applyFilters();
            }

            qInput?.addEventListener('input', applyFilters);
            typeSelect?.addEventListener('change', applyFilters);
            statusSelect?.addEventListener('change', applyFilters);
            sortSelect?.addEventListener('change', () => {
                const parsed = parseSort(sortSelect.value);
                sortKey = parsed.key;
                sortDir = parsed.dir;
                syncSortUi();
                refresh();
            });

            sortHeaders.forEach(th => {
                th.addEventListener('click', () => {
                    const key = th.dataset.sort;
                    if (sortKey === key)
                        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                    else {
                        sortKey = key;
                        sortDir = th.dataset.sortDefault === 'asc' ? 'asc' : 'desc';
                    }
                    syncSortUi();
                    refresh();
                });
            });

            syncSortUi();
            refresh();
        })();

        function updateDocTabCount() {
            const count = document.querySelectorAll('#attachmentList tbody tr').length;
            const docTab = document.querySelector('.tab-btn[data-tab="dokumenti"]');
            if (docTab) docTab.textContent = `Dokumenti (${count})`;
        }

        function loadAttachments() {
            $("#attachmentList").load("@Url.Action("GetAttachments", "Vehicle", new { vehicleId = Model.Id })", updateDocTabCount);
        }

        function deleteAttachment(id) {
            if (!confirm("Obrisati dokument?")) return;
            $.post("@Url.Action("DeleteAttachment", "Vehicle")", { id }, loadAttachments);
        }

        Dropzone.autoDiscover = false;
        $(function () {
            const dzEl = document.getElementById("vehicleDocDz");
            const btnNew = document.getElementById("btnNewDocument");
            let dz;

            if (dzEl) {
                dz = new Dropzone("#vehicleDocDz", {
                    paramName: "file",
                    maxFilesize: 10,
                    acceptedFiles: ".pdf,.jpg,.jpeg,.png",
                    dictDefaultMessage: "Povuci datoteke ovdje ili klikni za odabir (PDF, JPG, PNG · max 10 MB)",
                    success: function () {
                        loadAttachments();
                        dzEl.classList.add("is-collapsed");
                    }
                });
            }

            btnNew?.addEventListener("click", () => {
                dzEl?.classList.remove("is-collapsed");
                dz?.hiddenFileInput?.click();
            });
        });
    </script>
}
