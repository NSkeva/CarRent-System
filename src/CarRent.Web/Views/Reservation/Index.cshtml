@model IReadOnlyList<Reservation>
@{ ViewData["Title"] = "Rezervacije"; ViewData["Breadcrumbs"] = BreadcrumbHelper.Build("Home", "Rezervacije"); }
<partial name="_CrudIndexHeaderPartial" model='("Rezervacije", "+ Nova rezervacija", Url.Action("SearchRows"), "reservation-rows")' />
<div class="table-wrap rise-in">
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th><th>Kupac</th><th>Vozilo</th><th>Početak</th><th>Završetak</th><th>Status</th><th>Cijena</th><th></th>
            </tr>
        </thead>
        <tbody id="reservation-rows"><partial name="_IndexRows" model="Model" /></tbody>
    </table>
</div>
