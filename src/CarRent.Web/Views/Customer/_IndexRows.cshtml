@model IReadOnlyList<Customer>
@foreach (var item in Model)
{
    <tr>
        <td>@item.FirstName @item.LastName</td>
        <td>@item.Email</td>
        <td>@item.Phone</td>
        <td class="row-actions">
            <a asp-action="Details" asp-route-id="@item.Id">Detalji</a>
            <a asp-action="Edit" asp-route-id="@item.Id">Uredi</a>
            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline-form">@Html.AntiForgeryToken()<button type="submit" class="link-btn">Obriši</button></form>
        </td>
    </tr>
}
